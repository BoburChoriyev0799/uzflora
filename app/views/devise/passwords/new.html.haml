.bg-btm-container
  .container.content
    - devise_scope = 'devise.passwords.new'
    .row.login-registration-container.mtop20.content-container
      %h3.acenter.mbtm20
        = I18n.t('.title', scope: devise_scope)
      %p.acenter.mbtm20
        = I18n.t('.subtitle', scope: devise_scope)

      .col.col-md-7.col-sm-12.fcenter
        = form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f|
          .reg-form-cntainer.login-form
            = devise_error_messages!
            .row
              .col-md-2.col-sm-2.lbl-container
                %label{:for => "email"}
                  = I18n.t('.email', scope: devise_scope)
              .col-md-8.col-sm-8.input-container
                = f.email_field :email, autofocus: true, class: 'form-control'
              .col-md-2.col-sm-2.str-container
                %span.req *
            .row.mbtm20
              .col-md-2.col-sm-2.lbl-container
                \&nbsp;
              .col-md-8.col-sm-8.input-container.acenter
                = f.submit I18n.t('.submit', scope: devise_scope), class: 'mtop10 mm-mtop0 w100p btn-lg btn btn-info'
                %p.mtop10
                  =link_to I18n.t('.back_to_login', scope: devise_scope), new_user_session_path, class: 'lnk-success'
