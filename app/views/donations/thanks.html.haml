%style
  :plain
    .donation-thanks-wrap {
      max-width: 560px;
      margin: 24px auto 0;
      text-align: center;
    }
    .donation-thanks-title {
      font-family: 'Merriweather', Georgia, serif;
      font-weight: 900;
      font-size: 28px;
      color: #2f4a1c;
      margin-bottom: 10px;
    }
    .donation-thanks-message {
      color: #55605a;
      font-size: 15px;
      line-height: 1.7;
      margin-bottom: 30px;
    }
    .donation-method-card {
      border-radius: 10px;
      overflow: hidden;
      text-align: left;
      margin-bottom: 20px;
    }
    .donation-method-head {
      background: #046A38;
      color: #fff;
      font-weight: 700;
      padding: 8px 14px;
    }
    .donation-method-body {
      background: #DCEBC8;
      color: #223318;
      padding: 14px;
    }
    .donation-card-number-row {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }
    .donation-card-number {
      font-size: 19px;
      font-weight: 800;
      letter-spacing: .04em;
      color: #223318;
      word-break: break-all;
    }
    .donation-card-holder {
      font-size: 13px;
      color: #4a6b3a;
      margin-top: 6px;
    }
    .donation-copy-btn {
      border: none;
      border-radius: 8px;
      background: #046A38;
      color: #fff;
      font-size: 13px;
      font-weight: 700;
      padding: 7px 14px;
      cursor: pointer;
      flex-shrink: 0;
    }
    .donation-copy-btn:hover {
      background: #035a2f;
    }
    .donation-copy-confirm {
      font-size: 12px;
      color: #046A38;
      font-weight: 700;
      opacity: 0;
      transition: opacity .2s ease;
    }
    .donation-copy-confirm.visible {
      opacity: 1;
    }
    .donation-method-link {
      display: inline-block;
      padding: 9px 18px;
      border-radius: 8px;
      background: #046A38;
      color: #fff !important;
      font-weight: 700;
      text-decoration: none !important;
    }
    .donation-method-link:hover {
      background: #035a2f;
      color: #fff !important;
    }
    .donation-thanks-back {
      display: inline-block;
      margin-top: 10px;
      color: #4a6b3a;
      font-size: 13px;
      text-decoration: underline;
    }
    @media (max-width: 480px) {
      .donation-card-number {
        font-size: 16px;
      }
    }

.bg-btm-container
  .container.content
    .row.mtop20.content-container
      - t = 'donations.thanks'
      .donation-thanks-wrap
        %h2.donation-thanks-title= I18n.t('.title', scope: t)
        %p.donation-thanks-message= I18n.t('.message', scope: t)

        - if @payment_method == 'payme' && @donation_config.payme_url.present?
          .donation-method-card
            .donation-method-head Payme
            .donation-method-body
              = link_to I18n.t('.open_payme', scope: t), @donation_config.payme_url, class: 'donation-method-link', target: '_blank', rel: 'noopener'

        - if @payment_method == 'click' && @donation_config.click_url.present?
          .donation-method-card
            .donation-method-head Click
            .donation-method-body
              = link_to I18n.t('.open_click', scope: t), @donation_config.click_url, class: 'donation-method-link', target: '_blank', rel: 'noopener'

        - if @donation_config.card_number.present?
          .donation-method-card
            .donation-method-head= I18n.t('.card_title', scope: t)
            .donation-method-body
              .donation-card-number-row
                %span.donation-card-number= @donation_config.card_number
                %button.donation-copy-btn{type: 'button', data: {clipboard_text: @donation_config.card_number}}= I18n.t('.copy', scope: t)
                %span.donation-copy-confirm= I18n.t('.copied', scope: t)
              .donation-card-holder= @donation_config.card_holder

        = link_to I18n.t('.back_link', scope: t), donation_pages_path, class: 'donation-thanks-back'
