%style
  :plain
    .big-year-rules {
      max-width: 780px;
      margin: 24px auto 0;
      line-height: 1.75;
      font-size: 15px;
    }
    .big-year-intro {
      color: #3a3a3a;
      margin-bottom: 24px;
    }
    .big-year-toc {
      background: #f4f8ee;
      border: 1px solid #dfe9d0;
      border-radius: 8px;
      padding: 18px 22px;
      margin-bottom: 32px;
    }
    .big-year-toc-title {
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .04em;
      color: #4a7c2a;
      margin-bottom: 10px;
    }
    .big-year-toc ol {
      margin: 0;
      padding-left: 20px;
      columns: 1;
    }
    @media (min-width: 700px) {
      .big-year-toc ol {
        columns: 2;
        column-gap: 28px;
      }
    }
    .big-year-toc li {
      margin-bottom: 6px;
      break-inside: avoid;
    }
    .big-year-toc a {
      color: #2f4a1c;
      text-decoration: none;
    }
    .big-year-toc a:hover {
      text-decoration: underline;
      color: #4a7c2a;
    }
    .big-year-rules h3 {
      display: flex;
      align-items: center;
      margin: 36px 0 12px;
      font-size: 18px;
      font-weight: 700;
      color: #2f4a1c;
      scroll-margin-top: 90px;
    }
    .big-year-rules h3:first-of-type {
      margin-top: 0;
    }
    .big-year-rules .rules-section-number {
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: #7cb342;
      color: #fff;
      font-size: 13px;
      font-weight: 700;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      margin-right: 10px;
    }
    .big-year-rules p,
    .big-year-rules ul,
    .big-year-rules ol.plain-list {
      margin-bottom: 14px;
      color: #3a3a3a;
    }
    .big-year-rules ul,
    .big-year-rules ol.plain-list {
      padding-left: 22px;
    }
    .big-year-rules li {
      margin-bottom: 6px;
    }
    .big-year-rules .motto {
      font-style: italic;
      color: #2f4a1c;
    }
    .big-year-prizes {
      width: 100%;
      border-collapse: collapse;
      margin: 8px 0 20px;
    }
    .big-year-prizes th,
    .big-year-prizes td {
      border: 1px solid #dfe9d0;
      padding: 10px 14px;
      text-align: left;
    }
    .big-year-prizes th {
      background: #f4f8ee;
      color: #2f4a1c;
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: .03em;
    }
    .big-year-prizes tr:nth-child(even) td {
      background: #fafcf6;
    }
    .big-year-contacts {
      margin-top: 40px;
      padding-top: 24px;
      border-top: 1px solid #e2e0d4;
    }
    .big-year-contacts-title {
      font-weight: 700;
      color: #2f4a1c;
      margin-bottom: 12px;
    }
    .big-year-contacts-list {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }
    .big-year-contacts-list a {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 16px;
      border-radius: 20px;
      background: #7cb342;
      color: #fff !important;
      text-decoration: none !important;
      font-size: 14px;
      font-weight: 600;
    }
    .big-year-contacts-list a:hover {
      background: #689f38;
    }

.bg-btm-container
  .container.content
    - bg_scope = 'big_years.index'
    .row.big-year-container.mtop20
      .row
        %h4
          .big-year-text
            = I18n.t('.title', scope: bg_scope)
          %span.big_year_item.active= @current_year

      .row.big-year-rules-container.mtop20
        .big-year-rules
          - r = 'big_years.index.rules'
          .big-year-intro
            %p= I18n.t('intro', scope: r)

          .big-year-toc
            .big-year-toc-title= I18n.t('toc.title', scope: r)
            %ol
              - I18n.t('toc.items', scope: r).each_with_index do |item, i|
                %li= link_to item, "#section-#{i + 1}"

          - (1..13).each do |n|
            - s = "#{r}.section_#{n}"
            %h3{id: "section-#{n}"}
              %span.rules-section-number= n
              = I18n.t('title', scope: s)
            - case n
            - when 1
              %p= I18n.t('intro', scope: s)
              %ul
                - I18n.t('items', scope: s).each do |item|
                  %li= item
            - when 2, 10, 12, 13
              %p= I18n.t('text', scope: s)
            - when 3
              %p= I18n.t('text_1', scope: s)
              %p= I18n.t('text_2', scope: s)
              %ul
                - I18n.t('items', scope: s).each do |item|
                  %li= item
              %p= I18n.t('text_3', scope: s)
            - when 4, 5
              %p= I18n.t('text_1', scope: s)
              %ul
                - I18n.t('items', scope: s).each do |item|
                  %li= item
              %p= I18n.t('text_2', scope: s)
            - when 6
              %ul
                - I18n.t('criteria', scope: s).each do |criterion|
                  %li
                    %b= criterion[:title]
                    = criterion[:text]
            - when 7
              %p= I18n.t('text_1', scope: s)
              %ul
                - I18n.t('items', scope: s).each do |item|
                  %li= item
              %p= I18n.t('text_2', scope: s)
            - when 8
              %p= I18n.t('text_1', scope: s)
              %ul
                - I18n.t('items', scope: s).each do |item|
                  %li= item
              %p.motto= I18n.t('motto', scope: s)
            - when 9
              %p= I18n.t('text_1', scope: s)
              %ul
                - I18n.t('items', scope: s).each do |item|
                  %li= item
              %p= I18n.t('text_2', scope: s)
            - when 11
              %p= I18n.t('text_1', scope: s)
              %p= I18n.t('text_2', scope: s)
              %table.big-year-prizes
                %thead
                  %tr
                    %th= I18n.t('prizes.place', scope: s)
                    %th= I18n.t('prizes.prize', scope: s)
                %tbody
                  - I18n.t('prizes.rows', scope: s).each do |row|
                    %tr
                      %td= row[:place]
                      %td= row[:prize]
              %p= I18n.t('text_3', scope: s)

          .big-year-contacts
            .big-year-contacts-title= I18n.t('contacts_title', scope: r)
            .big-year-contacts-list
              = link_to 'uzflora.uz', root_path
