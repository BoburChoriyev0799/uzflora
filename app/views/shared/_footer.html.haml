.footer
  = render 'shared/nav_add_photo'
  .footer-inner
    %style
      :plain
        .footer-locale-switch {
          margin-bottom: 10px;
        }
        .footer-locale-switch a {
          display: inline-block;
          padding: 3px 12px;
          margin-left: 6px;
          border-radius: 14px;
          color: #fff !important;
          font-size: 12px;
          font-weight: 700;
          text-decoration: none !important;
          opacity: .75;
        }
        .footer-locale-switch a.active {
          opacity: 1;
          box-shadow: 0 0 0 2px rgba(255,255,255,.6);
        }
        .footer-locale-switch a:hover {
          opacity: 1;
        }
        /* Har til uchun alohida rang — O'Z yashil, RU sariq, EN qizil. */
        .footer-locale-switch a.locale-uz {
          background: #558b2f;
        }
        .footer-locale-switch a.locale-ru {
          background: #f9a825;
        }
        .footer-locale-switch a.locale-en {
          background: #c62828;
        }
        .footer-support-row {
          clear: both;
          text-align: center;
          padding-top: 14px;
          margin-top: 14px;
          border-top: 1px solid rgba(255,255,255,.15);
        }
        .footer-support-row a {
          color: #fff !important;
          font-size: 12px;
          font-weight: 700;
          text-decoration: none !important;
          opacity: .85;
        }
        .footer-support-row a:hover {
          opacity: 1;
          text-decoration: underline !important;
        }
    - footer_scope = 'shared.footer'
    .container
      .fleft
        %p
          =link_to root_path, style: 'display: inline-block; vertical-align: middle;' do
            = render 'shared/logo_icon', size: 22
          =link_to 'Uzflora.uz', root_path
          %br
          Developed by Bobur Choriyev
      .fright
        .footer-locale-switch.aright
          =link_to 'O\'Z', switch_locale_path(locale: :uz), class: "locale-uz #{'active' if I18n.locale == :uz}"
          =link_to 'RU', switch_locale_path(locale: :ru), class: "locale-ru #{'active' if I18n.locale == :ru}"
          =link_to 'EN', switch_locale_path(locale: :en), class: "locale-en #{'active' if I18n.locale == :en}"
        %p.aright
          = I18n.t('rights', scope: footer_scope)
          %br
          = I18n.t('contacts', scope: footer_scope)
          = mail_to 'boburchoriyev465@gmail.com', 'boburchoriyev465@gmail.com'
      .footer-support-row
        = link_to I18n.t('donation_link', scope: footer_scope), donation_pages_path
