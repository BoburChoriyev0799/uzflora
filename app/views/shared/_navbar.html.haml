%style
  :plain
    a.navbar-brand.uzflora-brand {
      display: flex;
      align-items: center;
      color: #8bc34a !important;
      font-weight: 700;
      font-size: 22px;
      letter-spacing: .3px;
      text-transform: none;
    }
    a.navbar-brand.uzflora-brand:hover,
    a.navbar-brand.uzflora-brand:focus {
      color: #8bc34a !important;
      opacity: .9;
    }
    .uzflora-brand-icon {
      display: flex;
      align-items: center;
      margin-right: 8px;
      line-height: 1;
    }
    /* Navbar menyu matnlari: katta harflar, qalin, oq — fon endi purple
       bo'lgani uchun qora matn deyarli o'qilmas edi (WCAG kontrast juda
       past), shuning uchun oq rang saqlab qolindi (talab ichida shu
       variant ham taklif qilingan edi). */
    .birds-nav ul.nav > li > a,
    .navbar-right ul.nav > li > a {
      text-transform: uppercase;
      font-weight: 700;
      letter-spacing: .02em;
    }
    /* Foydalanuvchi ismi (masalan "Choriyev Bobur") — katta harflarga
       aylanmaydi, chunki bu shaxs ismi, alohida shrift bilan ajratiladi. */
    .nav-profile-lnk span {
      font-family: 'Samsung Sharp Sans', 'Manrope', Arial, sans-serif !important;
      font-style: italic;
      font-size: 17px;
      text-transform: none;
      font-weight: 400;
      letter-spacing: normal;
    }
    .moderate-badge {
      display: inline-block;
      min-width: 18px;
      height: 18px;
      line-height: 18px;
      padding: 0 5px;
      border-radius: 999px;
      background: #d9363e;
      color: #fff !important;
      font-size: 11px;
      font-weight: 700;
      text-align: center;
      margin-left: 5px;
      vertical-align: middle;
    }
    /* Til tanlash (navbar, yuqori o'ng burchak) — xalqaro saytlarga o'xshab
       ixcham pill-tugmalar. Footer'даgi til tanlashga qo'shimcha (u ham
       saqlanib qoladi) — bu yerdagisi doimo ko'zga ko'rinadi. Mavjud
       o'ng menyu <ul>'ining ICHIDA (yangi alohida flex konteyner emas) —
       chunki alohida flex konteyner qo'shish avvalgi sinovda chap/o'ng
       menyu floatlarini buzib, ularni qayta ikki qatorga bo'lib yuborgan
       edi. Bitta <li> ichida 3ta kichik havola sifatida saqlash xavfsiz. */
    /* Bootstrap'ning `.nav > li > a { display:block; padding:10px 15px }`
       qoidasi ustunligi (specificity) yuqoriroq bo'lgani uchun bu yerda
       display/padding/margin/height'ni !important bilan majburlash kerak —
       aks holda 3ta til havolasi katta blok bo'lib bir-birining ustiga
       tushib qolardi (sinovda aynan shu xato topilgan edi). */
    .navbar-locale-switch a {
      display: inline-block !important;
      height: auto !important;
      width: auto !important;
      padding: 4px 9px !important;
      margin: 0 0 0 3px !important;
      border-radius: 14px;
      background: rgba(255, 255, 255, .12);
      color: #fff !important;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: .02em;
      text-decoration: none !important;
      opacity: .8;
      transition: background-color .15s ease, opacity .15s ease;
    }
    .navbar-locale-switch a:hover {
      opacity: 1;
      background: rgba(255, 255, 255, .22);
    }
    .navbar-locale-switch a.active {
      opacity: 1;
      background: rgba(255, 255, 255, .32);
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, .5);
    }
    @media (max-width: 1250px) {
      .navbar-locale-switch {
        display: block;
        text-align: center;
        padding: 10px 15px 8px;
        border-top: 1px solid rgba(255, 255, 255, .15);
      }
      .navbar-locale-switch a {
        padding: 5px 12px !important;
        margin: 0 4px !important;
        font-size: 12px;
      }
    }

%nav.navbar.birds-nav.navbar-fixed-top
  .container
    - navbar_scope = 'shared.navbar'
    .navbar-header
      / Navigation mobile
      %button.navbar-toggle.collapsed{"aria-controls" => "navbar", "aria-expanded" => "false", "data-target" => "#navbar", "data-toggle" => "collapse", :type => "button"}
        %span.sr-only
          = I18n.t('title', scope: navbar_scope)
        %span.icon-bar
        %span.icon-bar
        %span.icon-bar
      / Logo
      =link_to root_path, class: 'navbar-brand uzflora-brand', data: { name: 'TEST' } do
        %span.uzflora-brand-icon
          = render 'shared/logo_icon', size: 26
        %span.uzflora-brand-text uzflora.uz
    #navbar.collapse.navbar-collapse
      / Menu Left
      %ul.nav.navbar-nav
        -if current_user
          %li
            =nav_link_to "#{I18n.t('plants', scope: navbar_scope)}", plants_path
          %li
            =nav_link_to "#{I18n.t('bg', scope: navbar_scope)}", big_year_path
          %li
            =nav_link_to "#{I18n.t('birders', scope: navbar_scope)}", users_path
        %li
          =nav_link_to "#{I18n.t('about', scope: navbar_scope)}", about_pages_path
        -if current_user.try(:expert?)
          %li
            - pending_count = pending_plant_sightings_count
            - moderate_label = I18n.t('moderate_plants', scope: navbar_scope)
            - if pending_count.positive?
              - moderate_label = safe_join([moderate_label, content_tag(:span, pending_count, class: 'moderate-badge')], ' ')
            =nav_link_to moderate_label, pending_plant_sightings_path
      / Menu Right
      .navbar-right
        %ul.nav.navbar-nav.fright.mleft10
          -if current_user
            %li
              %span.nav-profile-lnk
                =link_to profile_path(current_user), class: 'profile-lnk' do
                  =image_tag current_user.avatar.thumb.url, class: 'img-circle'
                  %span= current_user.full_name.slice(0, 20)
            %li
              =link_to "#{I18n.t('exit', scope: navbar_scope)}", destroy_user_session_path, :method => :delete
          -else
            %li
              .btn-signup
                =link_to "#{I18n.t('sign-up', scope: navbar_scope)}", new_user_registration_path, class: 'btn btn-success'
            %li
              =link_to "#{I18n.t('sign-in', scope: navbar_scope)}", new_user_session_path
          / Til tanlash — yuqori o'ng burchak, o'sha bir xil <ul> ichida
          %li.navbar-locale-switch
            =link_to 'O\'Z', switch_locale_path(locale: :uz), class: "#{'active' if I18n.locale == :uz}"
            =link_to 'RU', switch_locale_path(locale: :ru), class: "#{'active' if I18n.locale == :ru}"
            =link_to 'EN', switch_locale_path(locale: :en), class: "#{'active' if I18n.locale == :en}"
