%style
  :plain
    a.navbar-brand.uzflora-brand {
      display: flex;
      align-items: center;
      color: #8bc34a !important;
      font-weight: 700;
      font-size: 22px;
      letter-spacing: .3px;
      text-transform: none;
    }
    a.navbar-brand.uzflora-brand:hover,
    a.navbar-brand.uzflora-brand:focus {
      color: #8bc34a !important;
      opacity: .9;
    }
    .uzflora-brand-icon {
      display: flex;
      align-items: center;
      margin-right: 8px;
      line-height: 1;
    }
    /* Navbar menyu matnlari: katta harflar, qalin, oq — fon endi burgundy
       bo'lgani uchun qora matn deyarli o'qilmas edi (WCAG kontrast juda
       past), shuning uchun oq rang saqlab qolindi (talab ichida shu
       variant ham taklif qilingan edi). */
    .birds-nav ul.nav > li > a,
    .navbar-right ul.nav > li > a {
      text-transform: uppercase;
      font-weight: 700;
      letter-spacing: .02em;
    }
    /* Foydalanuvchi ismi (masalan "Choriyev Bobur") — katta harflarga
       aylanmaydi, chunki bu shaxs ismi, alohida shrift bilan ajratiladi.
       max-width keng va white-space:nowrap — uzun ism-familiya hech qachon
       ikkinchi qatorga tushib "kesilgandek" ko'rinmasin. */
    .nav-profile-lnk {
      flex-shrink: 0;
    }
    .nav-profile-lnk span {
      font-family: 'Samsung Sharp Sans', 'Manrope', Arial, sans-serif !important;
      font-style: italic;
      font-size: 17px;
      text-transform: none;
      font-weight: 400;
      letter-spacing: normal;
      white-space: nowrap;
      max-width: 260px;
      overflow: visible;
      display: inline-block;
      vertical-align: middle;
    }
    /* Avatar — avval taxminan 36px (uploader'ning "thumb" versiyasi
       o'lchami) edi, endi kattaroq (50px) ko'rinishi uchun aniq
       width/height berilgan (border-radius:50% saqlanadi). */
    .nav-profile-lnk img.img-circle {
      width: 50px;
      height: 50px;
      object-fit: cover;
      vertical-align: middle;
    }
    .moderate-badge {
      display: inline-block;
      min-width: 18px;
      height: 18px;
      line-height: 18px;
      padding: 0 5px;
      border-radius: 999px;
      background: #d9363e;
      color: #fff !important;
      font-size: 11px;
      font-weight: 700;
      text-align: center;
      margin-left: 5px;
      vertical-align: middle;
    }
    /* Til tanlash (navbar, yuqori o'ng burchak) — endi bayroqli dropdown:
       faqat joriy til bayrog'i ko'rinadi, bosilganda qolgan ikki til
       ochiladi. Mantiq o'zgarmadi (switch_locale_path), faqat ko'rinishi.
       Standart Bootstrap .dropdown/.dropdown-toggle/.dropdown-menu
       mexanizmi ishlatiladi (bootstrap.min.js'da tayyor, alohida JS
       yozish shart emas) — shuning uchun bu yerda faqat ranglar/o'lcham
       burgundy mavzusiga moslashtiriladi. */
    .navbar-locale-dropdown {
      position: relative;
    }
    .navbar-locale-dropdown > .dropdown-toggle {
      display: inline-flex !important;
      align-items: center;
      height: auto !important;
      padding: 8px 12px !important;
      margin: 0 0 0 6px !important;
      border-radius: 999px;
      background: rgba(255, 255, 255, .14);
      cursor: pointer;
      transition: background-color .15s ease;
    }
    .navbar-locale-dropdown > .dropdown-toggle:hover,
    .navbar-locale-dropdown.open > .dropdown-toggle {
      background: rgba(255, 255, 255, .26);
    }
    .navbar-locale-flag {
      display: inline-flex;
      align-items: center;
      line-height: 1;
    }
    .navbar-flag-svg {
      width: 20px;
      height: 14px;
      border-radius: 2px;
      box-shadow: 0 0 0 1px rgba(255, 255, 255, .35);
      display: block;
    }
    .navbar-locale-dropdown > .dropdown-toggle .navbar-locale-code {
      margin-left: 6px;
      font-size: 12px;
      font-weight: 700;
    }
    .navbar-locale-dropdown > .dropdown-toggle > .caret {
      margin-left: 6px;
      border-top-color: #fff;
    }
    .navbar-locale-menu.dropdown-menu {
      min-width: 130px;
      margin-top: 10px;
      padding: 6px 0;
      background: #fff;
      border: none;
      border-radius: 10px;
      box-shadow: 0 6px 20px rgba(0,0,0,.22);
      overflow: hidden;
    }
    .navbar-locale-menu.dropdown-menu > li > a {
      display: flex !important;
      align-items: center;
      gap: 10px;
      padding: 9px 16px;
      color: #4d0013 !important;
      font-weight: 700;
      text-transform: none;
      letter-spacing: normal;
    }
    .navbar-locale-menu.dropdown-menu > li > a:hover,
    .navbar-locale-menu.dropdown-menu > li > a:focus {
      background: #f7eef0;
      color: #800020 !important;
    }
    .navbar-locale-menu .navbar-locale-code {
      font-size: 12px;
      opacity: .75;
    }
    /* Mobil hamburger menyu: dropdown ochilib-yopilishi (position:absolute)
       Bootstrap'ning ichki skrollanadigan .navbar-collapse.in konteyneri
       ichida ishonchsiz ishladi (sinovda: dropdown-menu eni noto'g'ri
       hisoblanib, ekran chetidan tashqariga chiqib ketdi). Shuning uchun
       mobilda BOSHQACHA, oddiyroq yechim: joriy bayroq + qolgan tillar
       BIR QATORDA, doim ko'rinadigan holda (dropdown ochish shart emas) —
       xuddi shu li/a elementlari, faqat CSS bilan "har doim ochiq"
       qilib ko'rsatiladi. */
    @media (max-width: 1250px) {
      .navbar-locale-dropdown {
        display: flex !important;
        align-items: center;
        justify-content: center;
        padding: 10px 15px;
        border-top: 1px solid rgba(255, 255, 255, .15);
      }
      .navbar-locale-dropdown > .dropdown-toggle {
        margin: 0 !important;
      }
      .navbar-locale-dropdown > .dropdown-toggle > .caret {
        display: none;
      }
      .navbar-locale-menu.dropdown-menu {
        display: flex !important;
        position: static;
        float: none;
        width: auto;
        min-width: 0;
        margin: 0;
        padding: 0;
        background: transparent;
        box-shadow: none;
        border: none;
      }
      .navbar-locale-menu.dropdown-menu > li {
        margin-left: 8px;
      }
      .navbar-locale-menu.dropdown-menu > li > a {
        padding: 8px 12px !important;
        border-radius: 999px;
        background: rgba(255, 255, 255, .14);
        color: #fff !important;
      }
      .navbar-locale-menu.dropdown-menu > li > a:hover,
      .navbar-locale-menu.dropdown-menu > li > a:focus {
        background: rgba(255, 255, 255, .26);
        color: #fff !important;
      }
      .navbar-locale-menu .navbar-locale-code {
        display: none;
      }
    }

%nav.navbar.birds-nav.navbar-fixed-top
  .container
    - navbar_scope = 'shared.navbar'
    .navbar-header
      / Navigation mobile
      %button.navbar-toggle.collapsed{"aria-controls" => "navbar", "aria-expanded" => "false", "data-target" => "#navbar", "data-toggle" => "collapse", :type => "button"}
        %span.sr-only
          = I18n.t('title', scope: navbar_scope)
        %span.icon-bar
        %span.icon-bar
        %span.icon-bar
      / Logo
      =link_to root_path, class: 'navbar-brand uzflora-brand', data: { name: 'TEST' } do
        %span.uzflora-brand-icon
          = render 'shared/logo_icon', size: 26
        %span.uzflora-brand-text uzflora.uz
    #navbar.collapse.navbar-collapse
      / Menu Left
      %ul.nav.navbar-nav
        -if current_user
          %li
            =nav_link_to "#{I18n.t('plants', scope: navbar_scope)}", plants_path
          %li
            =nav_link_to "#{I18n.t('bg', scope: navbar_scope)}", big_year_path
          %li
            =nav_link_to "#{I18n.t('birders', scope: navbar_scope)}", users_path
        %li
          =nav_link_to "#{I18n.t('about', scope: navbar_scope)}", about_pages_path
        -if current_user.try(:expert?)
          %li
            - pending_count = pending_plant_sightings_count
            - moderate_label = I18n.t('moderate_plants', scope: navbar_scope)
            - if pending_count.positive?
              - moderate_label = safe_join([moderate_label, content_tag(:span, pending_count, class: 'moderate-badge')], ' ')
            =nav_link_to moderate_label, pending_plant_sightings_path
      / Menu Right
      .navbar-right
        %ul.nav.navbar-nav.fright.mleft10
          -if current_user
            %li
              %span.nav-profile-lnk
                =link_to profile_path(current_user), class: 'profile-lnk' do
                  =image_tag current_user.avatar.thumb.url, class: 'img-circle'
                  %span= current_user.full_name.slice(0, 20)
            %li
              =link_to "#{I18n.t('exit', scope: navbar_scope)}", destroy_user_session_path, :method => :delete
          -else
            %li
              .btn-signup
                =link_to "#{I18n.t('sign-up', scope: navbar_scope)}", new_user_registration_path, class: 'btn btn-success'
            %li
              =link_to "#{I18n.t('sign-in', scope: navbar_scope)}", new_user_session_path
          / Til tanlash — yuqori o'ng burchak, bayroqli dropdown. Mantiq
          / o'zgarmadi: baribir switch_locale_path(locale: ...) ga link,
          / faqat ko'rinishi (3 alohida tugma -> joriy bayroq + ochiladigan
          / ro'yxat) o'zgardi.
          %li.dropdown.navbar-locale-dropdown
            %a.dropdown-toggle{href: '#', role: 'button', 'aria-haspopup' => 'true', 'aria-expanded' => 'false'}
              %span.navbar-locale-flag= locale_flag(I18n.locale)
              %span.navbar-locale-code= I18n.locale.to_s.upcase
              %span.caret
            %ul.dropdown-menu.pull-right.navbar-locale-menu{role: 'menu'}
              - I18n.available_locales.each do |loc|
                - next if loc == I18n.locale
                %li
                  =link_to switch_locale_path(locale: loc) do
                    %span.navbar-locale-flag= locale_flag(loc)
                    %span.navbar-locale-code= loc.to_s.upcase
