%style
  :plain
    .donation-wrap {
      max-width: 760px;
      margin: 24px auto 0;
    }
    .donation-title {
      font-family: 'Merriweather', Georgia, serif;
      font-weight: 900;
      font-size: 30px;
      color: #2f4a1c;
      text-align: center;
      margin-bottom: 14px;
      text-wrap: balance;
    }
    .donation-intro {
      color: #55605a;
      font-size: 15px;
      line-height: 1.7;
      text-align: center;
      max-width: 620px;
      margin: 0 auto 36px;
    }
    .donation-section-title {
      font-size: 17px;
      font-weight: 700;
      color: #2f4a1c;
      margin: 0 0 14px;
    }
    .donation-field {
      margin-bottom: 28px;
    }
    .donation-field label {
      display: block;
      font-size: 14px;
      font-weight: 700;
      color: #2f4a1c;
      margin-bottom: 8px;
    }
    .donation-amounts {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 14px;
    }
    .donation-amount-card,
    .donation-method-select-card {
      flex: 1 1 130px;
      text-align: center;
      padding: 16px 10px;
      background: #f7fbf1;
      border: 2px solid #e2ecd9;
      border-radius: 10px;
      font-weight: 700;
      color: #2f4a1c;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
      transition: border-color .15s ease, background-color .15s ease, color .15s ease;
      user-select: none;
    }
    .donation-amount-card:hover,
    .donation-method-select-card:hover {
      border-color: #b9d2a0;
    }
    .donation-amount-card.selected,
    .donation-method-select-card.selected {
      background: #DCEBC8;
      border-color: #046A38;
      color: #046A38;
    }
    .donation-amount-input {
      width: 100%;
      max-width: 260px;
      padding: 10px 12px;
      font-size: 16px;
      font-weight: 700;
      color: #223318;
      background: #fff;
      border: 2px solid #e2ecd9;
      border-radius: 8px;
    }
    .donation-amount-input:focus {
      outline: none;
      border-color: #046A38;
    }
    .donation-comment-input,
    .donation-donor-input {
      width: 100%;
      padding: 10px 12px;
      font-size: 15px;
      color: #223318;
      background: #fff;
      border: 2px solid #e2ecd9;
      border-radius: 8px;
      font-family: 'Samsung Sharp Sans', 'Manrope', Arial, sans-serif;
      resize: vertical;
    }
    .donation-comment-input:focus,
    .donation-donor-input:focus {
      outline: none;
      border-color: #046A38;
    }
    .donation-comment-count {
      display: block;
      text-align: right;
      font-size: 12px;
      color: #9ba896;
      margin-top: 4px;
    }
    .donation-methods-select {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }
    .donation-submit-btn {
      border: none !important;
      border-radius: 10px !important;
      font-weight: 700 !important;
      background-color: #046A38 !important;
      color: #fff !important;
      padding: 12px 0 !important;
      font-size: 16px !important;
    }
    .donation-submit-btn:hover,
    .donation-submit-btn:focus {
      background-color: #035a2f !important;
      color: #fff !important;
    }
    .donation-thanks {
      text-align: center;
      color: #55605a;
      font-size: 15px;
      line-height: 1.7;
      padding-top: 22px;
      margin-top: 8px;
      border-top: 1px solid #e2e0d4;
    }
    @media (max-width: 480px) {
      .donation-amount-card,
      .donation-method-select-card {
        flex: 1 1 42%;
      }
    }

.bg-btm-container
  .container.content
    .row.donation-container.mtop20.content-container
      - d = 'pages.donation'
      .donation-wrap
        %h2.donation-title= I18n.t('.title', scope: d)
        %p.donation-intro= I18n.t('.intro', scope: d)

        = form_with model: @donation, url: donations_path, method: :post, local: true do |f|
          .donation-field
            %h3.donation-section-title= I18n.t('.amounts_title', scope: d)
            .donation-amounts
              - [20000, 50000, 100000].each do |amount|
                %button.donation-amount-card{type: 'button', data: {amount: amount}, class: ('selected' if @donation.amount == amount)}= I18n.t('.amount_sum', scope: d, amount: number_with_delimiter(amount, delimiter: ' '))
              %button.donation-amount-card{type: 'button', data: {amount: 'other'}, class: ('selected' unless [20000, 50000, 100000].include?(@donation.amount))}= I18n.t('.amount_other', scope: d)
            %label{for: 'donation_amount'}= I18n.t('.amount_label', scope: d)
            = f.number_field :amount, id: 'donation_amount', class: 'donation-amount-input', min: 1, max: Donation::MAX_AMOUNT, required: true

          .donation-field
            %label{for: 'donation_comment'}= I18n.t('.comment_label', scope: d)
            = f.text_area :comment, id: 'donation_comment', class: 'donation-comment-input', maxlength: 100, rows: 3, placeholder: I18n.t('.comment_placeholder', scope: d)
            %span#donation-comment-count.donation-comment-count 0/100

          - if current_user.nil?
            .donation-field
              %label{for: 'donation_donor_name'}= I18n.t('.donor_name_label', scope: d)
              = f.text_field :donor_name, id: 'donation_donor_name', class: 'donation-donor-input', maxlength: 60, placeholder: I18n.t('.donor_name_placeholder', scope: d)

          .donation-field
            %h3.donation-section-title= I18n.t('.method_label', scope: d)
            .donation-methods-select
              - %w[payme click card].each do |m|
                %button.donation-method-select-card{type: 'button', data: {method: m}, class: ('selected' if @donation.payment_method == m)}= I18n.t(".method_#{m}", scope: d)
            = f.hidden_field :payment_method, id: 'donation_payment_method'

          .donation-field
            = f.submit I18n.t('.submit', scope: d), class: 'btn donation-submit-btn btn-lg btn-block'

        %p.donation-thanks= I18n.t('.thanks', scope: d)
