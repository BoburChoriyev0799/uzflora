%style
  :plain
    .plant-show-placeholder {
      width: 100%;
      aspect-ratio: 4 / 3;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 96px;
      background: linear-gradient(135deg, #eaf6ec 0%, #d3ecd8 100%);
      margin-bottom: 16px;
    }
    .plant-info-block {
      border: 1px solid #e2e2e2;
      border-radius: 6px;
      margin-bottom: 16px;
    }
    .plant-info-block-head {
      background: #f5f5f5;
      padding: 8px 14px;
      font-weight: 600;
      border-bottom: 1px solid #e2e2e2;
    }
    .plant-info-block-body {
      padding: 10px 14px;
    }
    .plant-info-block-body p {
      margin-bottom: 6px;
    }
    .plant-lbl {
      color: #888;
      margin-right: 4px;
    }
    .plant-red-book-badge {
      display: inline-block;
      background: #c0392b;
      color: #fff;
      font-size: 12px;
      padding: 3px 10px;
      border-radius: 10px;
      margin-bottom: 12px;
    }

.bg-btm-container
  .container.content
    - plant_scope = 'plants.show'
    .row.mtop20.mbtm20.content-container
      = link_to I18n.t('.back_to_list', scope: plant_scope), plants_path, class: 'btn btn-default mbtm20'

      .col.col-md-8.col-sm-12
        - if @plant.red_book?
          .plant-red-book-badge= I18n.t('.red_book_badge', scope: plant_scope)

        %h3= @plant.display_name(I18n.locale)
        - if @plant.species_uz.present? && @plant.species_uz != @plant.species_sci
          %p
            %i= @plant.species_sci
        - if @plant.species_ru.present?
          %p
            %span.plant-lbl= I18n.t('.russian_name', scope: plant_scope)
            = @plant.species_ru

        - if @plant.family_lat.present? || @plant.family_ru.present?
          .plant-info-block
            .plant-info-block-head= I18n.t('.family', scope: plant_scope)
            .plant-info-block-body
              - if @plant.family_lat.present?
                %p
                  %span.plant-lbl= I18n.t('.family_lat', scope: plant_scope)
                  = @plant.family_lat
              - if @plant.family_ru.present?
                %p
                  %span.plant-lbl= I18n.t('.family_ru', scope: plant_scope)
                  = @plant.family_ru

        - if @plant.life_form.present?
          .plant-info-block
            .plant-info-block-head= I18n.t('.life_form', scope: plant_scope)
            .plant-info-block-body
              %p= @plant.life_form

        - if @plant.protected_areas.present?
          .plant-info-block
            .plant-info-block-head= I18n.t('.protected_areas', scope: plant_scope)
            .plant-info-block-body
              %p= @plant.protected_areas

      .col-sm-12.col.col-md-4.fright.m-no-float
        .plant-show-placeholder 🌿
