%style
  :plain
    .plant-show-placeholder {
      width: 100%;
      aspect-ratio: 4 / 3;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 96px;
      background: linear-gradient(135deg, #eaf6ec 0%, #d3ecd8 100%);
      margin-bottom: 16px;
    }
    .plant-info-block {
      border: 1px solid #e2e2e2;
      border-radius: 6px;
      margin-bottom: 16px;
    }
    .plant-info-block-head {
      background: #f5f5f5;
      padding: 8px 14px;
      font-weight: 600;
      border-bottom: 1px solid #e2e2e2;
    }
    .plant-info-block-body {
      padding: 10px 14px;
    }
    .plant-info-block-body p {
      margin-bottom: 6px;
    }
    .plant-lbl {
      color: #888;
      margin-right: 4px;
    }
    .plant-red-book-badge {
      display: inline-block;
      background: #c0392b;
      color: #fff;
      font-size: 12px;
      padding: 3px 10px;
      border-radius: 10px;
      margin-bottom: 12px;
    }

.bg-btm-container
  .container.content
    - plant_scope = 'plants.show'
    .row.mtop20.mbtm20.content-container
      = link_to I18n.t('.back_to_list', scope: plant_scope), plants_path, class: 'btn btn-default mbtm20'

      .col.col-md-8.col-sm-12
        - if @plant.red_book?
          .plant-red-book-badge= I18n.t('.red_book_badge', scope: plant_scope)

        %h3= @plant.display_name(I18n.locale)
        - if @plant.species_uz.present? && @plant.species_uz != @plant.species_sci
          %p
            %i= @plant.species_sci
        - if @plant.species_ru.present?
          %p.plant-lbl= I18n.t('.russian_name', scope: plant_scope)
          = @plant.species_ru

        - if @plant.habitat.present?
          .plant-info-block
            .plant-info-block-head= I18n.t('.habitat', scope: plant_scope)
            .plant-info-block-body
              %p= @plant.habitat

        - if @plant.life_form.present?
          .plant-info-block
            .plant-info-block-head= I18n.t('.life_form', scope: plant_scope)
            .plant-info-block-body
              %p= @plant.life_form

        - if @plant.economic.present?
          .plant-info-block
            .plant-info-block-head= I18n.t('.economic', scope: plant_scope)
            .plant-info-block-body
              %p= @plant.economic

        - if @plant.areal.present? || @plant.distr_ca.present? || @plant.distr_uz.present?
          .plant-info-block
            .plant-info-block-head= I18n.t('.distribution', scope: plant_scope)
            .plant-info-block-body
              - if @plant.areal.present?
                %p
                  %span.plant-lbl= I18n.t('.areal', scope: plant_scope)
                  = @plant.areal
              - if @plant.distr_ca.present?
                %p
                  %span.plant-lbl= I18n.t('.distr_ca', scope: plant_scope)
                  = @plant.distr_ca
              - if @plant.distr_uz.present?
                %p
                  %span.plant-lbl= I18n.t('.distr_uz', scope: plant_scope)
                  = @plant.distr_uz
              - if @plant.admin_regions.present?
                %p
                  %span.plant-lbl= I18n.t('.admin_regions', scope: plant_scope)
                  = @plant.admin_regions

        - if @plant.opt.present?
          .plant-info-block
            .plant-info-block-head= I18n.t('.protected_areas', scope: plant_scope)
            .plant-info-block-body
              %p= @plant.opt

        - if @plant.synonyms.present?
          .plant-info-block
            .plant-info-block-head= I18n.t('.synonyms', scope: plant_scope)
            .plant-info-block-body
              %p= @plant.synonyms

      .col-sm-12.col.col-md-4.fright.m-no-float
        .plant-show-placeholder 🌿

        .plant-info-block
          .plant-info-block-head= I18n.t('.taxonomy', scope: plant_scope)
          .plant-info-block-body
            - if @plant.otdel_sci.present?
              %p
                %span.plant-lbl= I18n.t('.otdel', scope: plant_scope)
                = @plant.otdel_sci
            - if @plant.class_sci.present?
              %p
                %span.plant-lbl= I18n.t('.class_name', scope: plant_scope)
                = @plant.class_sci
            - if @plant.order_sci.present?
              %p
                %span.plant-lbl= I18n.t('.order', scope: plant_scope)
                = @plant.order_sci
            - if @plant.family_apg_sci.present?
              %p
                %span.plant-lbl= I18n.t('.family', scope: plant_scope)
                = @plant.family_apg_sci
            - if @plant.genus_sci.present?
              %p
                %span.plant-lbl= I18n.t('.genus', scope: plant_scope)
                = @plant.genus_sci
            %p
              %span.plant-lbl= I18n.t('.species', scope: plant_scope)
              %i= @plant.species_sci

        - if @plant.endemism.present? || @plant.status.present?
          .plant-info-block
            .plant-info-block-head= I18n.t('.status_title', scope: plant_scope)
            .plant-info-block-body
              - if @plant.status.present?
                %p
                  %span.plant-lbl= I18n.t('.general_status', scope: plant_scope)
                  = @plant.status
              - if @plant.endemism.present?
                %p
                  %span.plant-lbl= I18n.t('.endemism', scope: plant_scope)
                  = @plant.endemism

        - if @plant.plantlist_url.present? || @plant.plantarium_url.present?
          .plant-info-block
            .plant-info-block-head= I18n.t('.external_sources', scope: plant_scope)
            .plant-info-block-body
              - if @plant.plantlist_url.present?
                %p= link_to 'The Plant List', @plant.plantlist_url, target: '_blank', rel: 'noopener'
              - if @plant.plantarium_url.present?
                %p= link_to I18n.t('.plantarium_photos', scope: plant_scope), @plant.plantarium_url, target: '_blank', rel: 'noopener'
