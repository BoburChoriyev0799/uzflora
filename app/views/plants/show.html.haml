%style
  :plain
    .plant-show-placeholder {
      width: 100%;
      aspect-ratio: 4 / 3;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 96px;
      background: linear-gradient(135deg, #eaf6ec 0%, #d3ecd8 100%);
      margin-bottom: 16px;
    }
    .plant-info-block {
      border-radius: 6px;
      margin-bottom: 16px;
      overflow: hidden;
    }
    .plant-info-block-head {
      background: #046A38;
      color: #fff;
      padding: 8px 14px;
      font-weight: 700;
    }
    .plant-info-block-body {
      background: #DCEBC8;
      color: #223318;
      padding: 10px 14px;
    }
    .plant-info-block-body p {
      margin-bottom: 6px;
    }
    .plant-lbl {
      color: #4a6b3a;
      margin-right: 4px;
    }
    .plant-red-book-badge {
      display: inline-block;
      background: #c0392b;
      color: #fff;
      font-size: 12px;
      padding: 3px 10px;
      border-radius: 10px;
      margin-bottom: 12px;
    }
    .plant-taxonomy-table {
      width: 100%;
      table-layout: fixed;
    }
    .plant-taxonomy-table td {
      padding: 3px 0;
      vertical-align: top;
      word-wrap: break-word;
      overflow-wrap: break-word;
    }
    .plant-taxonomy-table td.plant-lbl {
      width: 90px;
      white-space: nowrap;
      padding-right: 8px;
    }
    .plant-taxon-ru {
      color: #4a6b3a;
      margin-left: 6px;
    }
    /* Foydalanuvchi rasmlari galereyasi — bosh sahifadagi rasm
       kartochkalari (welcome-gallery) bilan bir xil vizual uslub
       (yumaloq burchak, soya), lekin bu yerda tor ustunga mos ravishda
       bitta ustunli ro'yxat sifatida. */
    .plant-photos-title {
      color: #2f4a1c !important;
      margin-bottom: 12px;
    }
    .plant-photos-gallery {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .plant-photo-card {
      border-radius: 8px;
      overflow: hidden;
      background: #fff;
      box-shadow: 0 2px 10px rgba(0,0,0,.08);
    }
    .plant-photo-img {
      width: 100%;
      display: block;
    }
    .plant-photo-meta {
      padding: 10px 12px;
    }
    .plant-photo-meta p {
      margin-bottom: 3px;
      font-size: 13px;
      color: #666;
    }
    .plant-photo-author a {
      color: #1e5620;
    }
    .plant-photos-empty {
      color: #888;
      font-style: italic;
    }

.bg-btm-container
  .container.content
    - plant_scope = 'plants.show'
    .row.mtop20.mbtm20.content-container
      = link_to I18n.t('.back_to_list', scope: plant_scope), plants_path, class: 'btn btn-default mbtm20'

      .col.col-md-8.col-sm-12
        - if @plant.red_book?
          .plant-red-book-badge= I18n.t('.red_book_badge', scope: plant_scope)

        %h3= @plant.display_name(I18n.locale)
        - if @plant.species_uz.present? && @plant.species_uz != @plant.species_sci
          %p
            %i= @plant.species_sci
        - if @plant.species_ru.present?
          %p
            %span.plant-lbl= I18n.t('.russian_name', scope: plant_scope)
            = @plant.species_ru

        - taxonomy_rows = plant_taxonomy_rows(@plant)
        - if taxonomy_rows.any?
          .plant-info-block
            .plant-info-block-head= I18n.t('.taxonomy', scope: plant_scope)
            .plant-info-block-body
              %table.plant-taxonomy-table
                - taxonomy_rows.each do |label_key, lat, ru|
                  %tr
                    %td.plant-lbl= I18n.t(".taxon_#{label_key}", scope: plant_scope)
                    %td
                      - if lat.present?
                        %i= lat
                      - if ru.present?
                        %span.plant-taxon-ru= "(#{ru})"

        - life_form_text = @plant.life_form_localized(I18n.locale)
        - if life_form_text.present?
          .plant-info-block
            .plant-info-block-head= I18n.t('.life_form', scope: plant_scope)
            .plant-info-block-body
              %p= life_form_text

        - habitat_env_text = @plant.habitat_env_localized(I18n.locale)
        - habitat_place_text = @plant.habitat_place_localized(I18n.locale)
        - if habitat_env_text.present? || habitat_place_text.present?
          .plant-info-block
            .plant-info-block-head= I18n.t('.habitat', scope: plant_scope)
            .plant-info-block-body
              - if habitat_env_text.present?
                %p
                  %span.plant-lbl= I18n.t('.habitat_env', scope: plant_scope)
                  = habitat_env_text
              - if habitat_place_text.present?
                %p
                  %span.plant-lbl= I18n.t('.habitat_place', scope: plant_scope)
                  = habitat_place_text

        - usage_text = @plant.usage_localized(I18n.locale)
        - if usage_text.present?
          .plant-info-block
            .plant-info-block-head= I18n.t('.usage', scope: plant_scope)
            .plant-info-block-body
              %p= usage_text

        - range_world_text = @plant.range_world_localized(I18n.locale)
        - range_central_asia_text = @plant.range_central_asia_localized(I18n.locale)
        - range_uzbekistan_text = @plant.range_uzbekistan_localized(I18n.locale)
        - if range_world_text.present? || range_central_asia_text.present? || range_uzbekistan_text.present?
          .plant-info-block
            .plant-info-block-head= I18n.t('.range', scope: plant_scope)
            .plant-info-block-body
              - if range_world_text.present?
                %p
                  %span.plant-lbl= I18n.t('.range_world', scope: plant_scope)
                  = range_world_text
              - if range_central_asia_text.present?
                %p
                  %span.plant-lbl= I18n.t('.range_central_asia', scope: plant_scope)
                  = range_central_asia_text
              - if range_uzbekistan_text.present?
                %p
                  %span.plant-lbl= I18n.t('.range_uzbekistan', scope: plant_scope)
                  = range_uzbekistan_text

        - if @plant.protected_areas.present?
          .plant-info-block
            .plant-info-block-head= I18n.t('.protected_areas', scope: plant_scope)
            .plant-info-block-body
              %p= @plant.protected_areas

      .col-sm-12.col.col-md-4.fright.m-no-float
        - if @sightings.present?
          %h4.plant-photos-title= I18n.t('.photos_title', scope: plant_scope)
          .plant-photos-gallery
            - @sightings.each do |sighting|
              .plant-photo-card
                = link_to plant_sighting_path(sighting) do
                  = image_tag sighting.photo.small.url, class: 'plant-photo-img'
                .plant-photo-meta
                  - if sighting.timestamp.present?
                    %p.plant-photo-date= date_format(sighting.timestamp)
                  - if sighting.address_valid?
                    %p.plant-photo-place= sighting.address_string
                  %p.plant-photo-author
                    = I18n.t('.photo_by', scope: plant_scope)
                    = link_to sighting.user.full_name, profile_path(sighting.user)
        - else
          .plant-show-placeholder 🌿
          %p.plant-photos-empty.acenter= I18n.t('.photos_empty', scope: plant_scope)
