- content_for :head do
  / OpenStreetMap (Leaflet) — faqat shu (mehmon) sahifada kerak, shuning
  / uchun umumiy layout'ga emas, shu yerga qo'shildi.
  %link{rel: "stylesheet", href: "https://unpkg.com/leaflet@1.9.4/dist/leaflet.css", integrity: "sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=", crossorigin: ""}
  %script{src: "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js", integrity: "sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=", crossorigin: ""}
  / Sarlavha uchun — faqat shu sahifada, saytning qolgan qismidagi
  / shriftga tegilmadi.
  %link{rel: "preconnect", href: "https://fonts.googleapis.com"}
  %link{rel: "preconnect", href: "https://fonts.gstatic.com", crossorigin: ""}
  %link{rel: "stylesheet", href: "https://fonts.googleapis.com/css2?family=Merriweather:wght@700;900&display=swap"}

%style
  :plain
    .welcome-title {
      font-family: 'Merriweather', Georgia, serif;
      font-weight: 900;
      font-size: 36px;
      color: #2f4a1c;
      letter-spacing: -.01em;
      text-wrap: balance;
      margin-bottom: 12px;
    }
    .welcome-intro {
      max-width: 640px;
      margin: 0 auto 10px;
      color: #55605a;
      font-size: 17px;
      line-height: 1.7;
      font-family: 'Samsung Sharp Sans', 'Manrope', Arial, sans-serif !important;
      font-weight: 700 !important;
    }
    .welcome-gallery-row {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
    }
    .welcome-gallery-cell {
      flex: 1 1 18%;
      min-width: 150px;
      position: relative;
      border-radius: 8px;
      overflow: hidden;
      background: #eef4ea;
      box-shadow: 0 2px 10px rgba(0,0,0,.08);
    }
    .welcome-gallery-cell img {
      width: 100%;
      height: 230px;
      object-fit: cover;
      display: block;
      opacity: 0;
      transition: opacity .5s ease-in-out;
    }
    .welcome-gallery-cell img.loaded {
      opacity: 1;
    }
    .welcome-gallery-caption {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(to top, rgba(0,0,0,.65), rgba(0,0,0,0));
      color: #fff;
      font-size: 12px;
      font-weight: 600;
      padding: 18px 8px 8px;
      min-height: 14px;
    }
    .welcome-gallery-empty {
      flex: 1 1 100%;
      height: 230px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #eaf6ec 0%, #d3ecd8 100%);
      border-radius: 8px;
      color: #4a7c2a;
      font-size: 48px;
    }
    /* Galereya (5ta surat) o'zining ustunini (col-md-9) to'liq to'ldirgani
       uchun "Bizga qo'shiling" kartasiga (yonidagi col-md-3) to'g'ridan-
       to'g'ri yopishib qolardi (o'lchab tasdiqlandi: oralig'i 0px edi).
       Ustunlar eniga (12 ustun) tegmasdan, faqat galereyaning O'ZINI
       (flex konteyner sifatida) biroz torайtirib, orasiga bo'sh joy
       ochamiz — bu xavfsiz, chunki flex elementlar konteyner kichrayganда
       o'zlari mutanosib ravishda kichrayadi (float kabi keyingi qatorga
       "sakrab" tushish xavfi yo'q). Faqat kompyuterda (>=992px) — mobilda
       ustunlar baribir bir-birining OSTIGA tushadi, gorizontal oraliq
       kerak emas. */
    @media (min-width: 992px) {
      .welcome-gallery-row {
        margin-right: 24px;
      }
    }
    .welcome-cta-col {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 28px 26px;
      background: #f7fbf1;
      border: 1px solid #e2ecd9;
      border-radius: 14px;
      box-shadow: 0 4px 20px rgba(47,74,28,.09);
    }
    .welcome-cta-eyebrow {
      font-family: 'Merriweather', Georgia, serif;
      font-weight: 800;
      font-size: 21px;
      color: #2f4a1c;
      margin-bottom: 10px;
      text-wrap: balance;
    }
    .welcome-cta-col p.welcome-cta-text {
      color: #55605a;
      font-size: 15px;
      line-height: 1.6;
      margin-bottom: 22px;
    }
    /* Kirish/Ro'yxatdan o'tish — ikkalasi ham zamonaviy, aniq fon rangли
       tugmaga o'xshasin (avval faqat Ro'yxatdan o'tishда yorqin fon bor
       edi). Sayt palitrasidagi ranglar: Kirish — burgundy, Ro'yxatdan
       o'tish — to'q yashil (bir-biridan farqli, lekin mos juft). */
    .welcome-btn-signin,
    .welcome-btn-signup {
      border: none !important;
      border-radius: 10px !important;
      font-weight: 700 !important;
      letter-spacing: .01em;
      transition: background-color .15s ease, box-shadow .15s ease;
    }
    .welcome-btn-signin {
      background-color: #800020 !important;
      color: #fff !important;
    }
    .welcome-btn-signin:hover,
    .welcome-btn-signin:focus {
      background-color: #66001a !important;
      color: #fff !important;
    }
    .welcome-btn-signup {
      background-color: #1e5620 !important;
      color: #fff !important;
    }
    .welcome-btn-signup:hover,
    .welcome-btn-signup:focus {
      background-color: #163f18 !important;
      color: #fff !important;
    }
    .welcome-map-title {
      font-family: 'Merriweather', Georgia, serif;
      font-weight: 700;
      color: #2f4a1c;
      margin-top: 40px;
      margin-bottom: 14px;
    }
    #welcome_map_canvas {
      width: 100%;
      height: 480px;
      border-radius: 6px;
    }
    @media (max-width: 991px) {
      .welcome-gallery-cell {
        flex: 1 1 30%;
      }
      .welcome-cta-col {
        margin-top: 22px;
      }
    }
    @media (max-width: 767px) {
      .welcome-title {
        font-size: 26px;
      }
      .welcome-gallery-cell {
        flex: 1 1 45%;
      }
      .welcome-gallery-cell img {
        height: 160px;
      }
      #welcome_map_canvas {
        height: 320px;
      }
      .welcome-cta-col {
        padding: 22px 20px;
      }
    }

.bg-btm-container
  .container.content
    - w = 'plants.welcome'
    .row.mtop20
      %h3.acenter.welcome-title= I18n.t('.title', scope: w)
      %p.welcome-intro.acenter= I18n.t('.subtitle', scope: w)

    .row.mtop30
      .col-md-9.col-sm-12
        - if @recent_sightings.present?
          .welcome-gallery-row{data: {sightings: @recent_sightings.map { |s| { photo: s.photo.display.url, name: (s.plant.present? ? s.plant.display_name(I18n.locale) : nil) } }.to_json}}
            - 5.times do |i|
              .welcome-gallery-cell{id: "welcome-cell-#{i}"}
                %img.welcome-gallery-img
                .welcome-gallery-caption
        - else
          .welcome-gallery-row
            .welcome-gallery-empty 🌿

      .col-md-3.col-sm-12.welcome-cta-col
        .welcome-cta-eyebrow= I18n.t('.cta_eyebrow', scope: w)
        %p.welcome-cta-text= I18n.t('.cta_text', scope: w)
        = link_to I18n.t('.sign_in', scope: w), new_user_session_path, class: 'btn welcome-btn-signin btn-lg btn-block mbtm10'
        = link_to I18n.t('.sign_up', scope: w), new_user_registration_path, class: 'btn welcome-btn-signup btn-lg btn-block'

    .row
      %h4.welcome-map-title.acenter= I18n.t('.map_title', scope: w)
      #welcome_map_canvas{data: {points: @map_sightings.map { |s| { lat: s.latitude, lng: s.longitude, name: s.plant.present? ? s.plant.display_name(I18n.locale) : nil } }.to_json}}
